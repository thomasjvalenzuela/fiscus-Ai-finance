# Fiscus — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit it.

# OpenAI API key (optional)
# Enables AI categorization, AI Advisor chat, and AI budget suggestions.
# Get your key at: https://platform.openai.com/api-keys
# You can also set this from the app's Settings page (stored in localStorage).
VITE_OPENAI_API_KEY=
